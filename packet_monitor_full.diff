+
+        lv_label_set_text(
+            tileTitleLabels_[index],
+            items_[index].title);
+
+        lv_obj_set_style_text_align(
+            tileTitleLabels_[index],
+            LV_TEXT_ALIGN_CENTER,
+            LV_PART_MAIN);
+
+        lv_obj_set_style_text_font(
+            tileTitleLabels_[index],
+            &lv_font_montserrat_12,
+            LV_PART_MAIN);
+
+        lv_obj_align(
+            tileTitleLabels_[index],
+            LV_ALIGN_TOP_MID,
+            0,
+            23);
+
+        lv_label_set_text(
+            tileStateLabels_[index],
+            isItemImplemented(index)
