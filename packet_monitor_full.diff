+
+void WiFiPacketMonitorScreen::setDetailVisible(
+    const bool visible)
+{
+    detailVisible_ = visible;
+
+    if (
+        overviewPanel_ == nullptr ||
+        detailPanel_ == nullptr)
+    {
+        return;
+    }
+
+    if (detailVisible_)
+    {
+        lv_obj_add_flag(
+            overviewPanel_,
+            LV_OBJ_FLAG_HIDDEN);
+
+        lv_obj_remove_flag(
+            detailPanel_,
+            LV_OBJ_FLAG_HIDDEN);
+    }
+    else
+    {
+        lv_obj_add_flag(
+            detailPanel_,
+            LV_OBJ_FLAG_HIDDEN);
+
+        lv_obj_remove_flag(
+            overviewPanel_,
+            LV_OBJ_FLAG_HIDDEN);
+    }
+}
+
+void WiFiPacketMonitorScreen::requestParent()
+{
+    if (parentCallback_ != nullptr)
+    {
+        parentCallback_(parentContext_);
+    }
+}
